<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-seed-countries" author="newsworld">
        <loadData tableName="countries"
                  file="db/data/countries.csv"
                  relativeToChangelogFile="false"
                  separator=","
                  usePreparedStatements="true">
            <column name="code"          type="STRING"/>
            <column name="name"          type="STRING"/>
            <column name="continent"     type="STRING"/>
            <column name="population"    type="NUMERIC"/>
            <column name="week_day"      type="NUMERIC"/>
            <column name="media_name"    type="STRING"/>
            <column name="media_url"     type="STRING"/>
            <column name="rss_url"       type="STRING"/>
            <column name="rss_available" type="BOOLEAN"/>
            <column name="iana_timezone" type="STRING"/>
            <column name="language"      type="STRING"/>
        </loadData>
    </changeSet>

</databaseChangeLog>
