<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NewsWorldDashboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryDark</item>
        <item name="colorOnPrimaryContainer">@color/colorOnSurface</item>
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/colorCard</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceDim</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.NewsWorld.BottomSheetDialog</item>
    </style>

    <style name="ThemeOverlay.NewsWorld.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.NewsWorld.BottomSheet</item>
    </style>

    <style name="Widget.NewsWorld.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/colorSurface</item>
    </style>
</resources>
